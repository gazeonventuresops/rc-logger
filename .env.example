# Relational Database connection string (PostgreSQL for Neon/Supabase)
DATABASE_URL="postgresql://username:password@hostname:5432/database?sslmode=require"

# Random 32 character session encryption key (NextAuth / JWT encryption)
NEXTAUTH_SECRET="your-random-32-char-jwt-encryption-key-here"

# Microsoft Azure Active Directory (Graph API / OneDrive)
ONEDRIVE_CLIENT_ID="your-azure-app-client-id-here"
ONEDRIVE_CLIENT_SECRET="your-azure-app-client-secret-here"
ONEDRIVE_TENANT_ID="your-azure-directory-tenant-id-here"
